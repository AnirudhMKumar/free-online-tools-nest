---
/**
 * CategoryCard — card linking to a category page.
 * Used on the homepage and category directory.
 */
interface Props {
  slug: string;
  name: string;
  description: string;
  icon: string;
  color: string;
  toolCount: number;
  topTools?: string[];
  href?: string;
  countLabel?: string;
}

const { slug, name, description, icon, color, toolCount, topTools = [], href, countLabel } = Astro.props;
const categoryHref = href || `/categories/${slug}/`;
---

<a
  href={categoryHref}
  class="category-card group"
  id={`category-${slug}`}
  style={`--category-accent: ${color};`}
>
  <span class="category-card-accent" aria-hidden="true"></span>
  <span class="category-card-head">
    <span class="category-card-icon" aria-hidden="true">{icon}</span>
    <span class="metadata-badge">{countLabel || `${toolCount} ${toolCount === 1 ? "tool" : "tools"}`}</span>
  </span>
  <span class="category-card-title-row">
    <span class="category-card-title">{name}</span>
    <svg class="tool-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14"></path>
      <path d="m12 5 7 7-7 7"></path>
    </svg>
  </span>
  <span class="category-card-description">{description}</span>
  {topTools.length > 0 && (
    <span class="category-card-tools" aria-label={`Popular ${name}`}>
      {topTools.slice(0, 3).map((toolName) => (
        <span>{toolName}</span>
      ))}
    </span>
  )}
</a>
