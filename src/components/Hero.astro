---
/**
 * Hero — homepage hero section with mesh gradient backdrop.
 * The multi-stop gradient (develop → preview → ship) is the single
 * decorative chrome element per DESIGN.md.
 */
import { SITE } from "../data/tools";
---

<section class="relative overflow-hidden" id="hero">
  <!-- Mesh gradient backdrop -->
  <div class="hero-gradient absolute inset-0 opacity-30 dark:opacity-20 pointer-events-none" aria-hidden="true"></div>

  <div class="container-page relative z-10 py-24 md:py-32 lg:py-40 text-center">
    <!-- Eyebrow badge -->
    <div class="inline-flex items-center gap-2 mb-6 px-4 py-1.5 bg-canvas rounded-full shadow-card text-sm text-body">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-success animate-pulse" aria-hidden="true"></span>
      Free, fast, and private
    </div>

    <!-- Headline -->
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold text-ink max-w-3xl mx-auto" style="letter-spacing: -2.4px; line-height: 1;">
      Free tools for text, code, and&nbsp;math.
    </h1>

    <!-- Sub-headline -->
    <p class="mt-6 text-lg text-body max-w-xl mx-auto leading-relaxed">
      {SITE.description}
    </p>

    <!-- Search bar -->
    <div class="mt-10 max-w-lg mx-auto">
      <div class="relative">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 text-mute pointer-events-none"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="hero-search"
          type="search"
          placeholder="Search tools…"
          autocomplete="off"
          class="w-full h-12 pl-12 pr-4 bg-canvas border border-hairline rounded-xl text-base text-ink placeholder:text-mute shadow-card focus:shadow-elevated focus:border-link transition-all duration-200 outline-none"
          aria-label="Search tools"
        />
      </div>
      <!-- Search results dropdown -->
      <div id="hero-search-results" class="hidden mt-2 bg-canvas rounded-lg shadow-modal border border-hairline overflow-hidden text-left" role="listbox"></div>
    </div>

    <!-- CTA buttons -->
    <div class="mt-8 flex items-center justify-center gap-3 flex-wrap">
      <a href="/tools/" class="btn-primary">
        Browse all tools
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hero-gradient {
    background: radial-gradient(ellipse 120% 80% at 50% 0%,
      #007cf0 0%,
      #00dfd8 25%,
      #7928ca 50%,
      #ff0080 75%,
      #f9cb28 100%
    );
    background-size: 200% 200%;
    animation: mesh-shift 12s ease-in-out infinite;
    filter: blur(60px);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-gradient {
      animation: none;
    }
  }
</style>

<script>
  // Hero search — client-side instant search
  import { TOOLS } from "../data/tools";

  const input = document.getElementById("hero-search") as HTMLInputElement;
  const results = document.getElementById("hero-search-results");

  function renderResults(query: string) {
    if (!results) return;
    const q = query.toLowerCase().trim();
    if (!q) {
      results.classList.add("hidden");
      return;
    }

    const matches = TOOLS.filter(
      (t) =>
        t.name.toLowerCase().includes(q) ||
        t.description.toLowerCase().includes(q) ||
        t.keywords.some((k) => k.includes(q))
    ).slice(0, 5);

    if (matches.length === 0) {
      results.innerHTML = `<div class="px-4 py-3 text-sm text-mute">No tools found for \u201C${q}\u201D</div>`;
    } else {
      results.innerHTML = matches
        .map(
          (t) =>
            `<a href="/tools/${t.slug}/" role="option" class="flex items-center gap-3 px-4 py-3 hover:bg-canvas-soft-2 transition-colors duration-100 no-underline">
              <span class="text-lg shrink-0">${t.icon}</span>
              <div>
                <div class="text-sm font-medium text-ink">${t.name}</div>
                <div class="text-xs text-mute line-clamp-1">${t.description}</div>
              </div>
            </a>`
        )
        .join("");
    }
    results.classList.remove("hidden");
  }

  input?.addEventListener("input", (e) => {
    renderResults((e.target as HTMLInputElement).value);
  });

  // Close on click outside
  document.addEventListener("click", (e) => {
    if (!input?.contains(e.target as Node) && !results?.contains(e.target as Node)) {
      results?.classList.add("hidden");
    }
  });

  // Close on escape
  input?.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      results?.classList.add("hidden");
      input.blur();
    }
  });
</script>
