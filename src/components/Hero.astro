---
/**
 * Hero - compact utility-first homepage hero.
 */
import { SITE } from "../data/tools";
import { useTranslations, getLangFromUrl } from "../i18n/utils";

const t = useTranslations(getLangFromUrl(Astro.url));

const quickTasks = [
  { label: "Compress images", href: "/tools/image-compressor/", accent: "#00a78e" },
  { label: "Format JSON", href: "/tools/json-formatter/", accent: "#7928ca" },
  { label: "Compress PDF", href: "/tools/pdf-compressor/", accent: "#ee0000" },
  { label: "Merge PDF", href: "/tools/pdf-merger/", accent: "#f97316" },
  { label: "QR codes", href: "/tools/qr-code-generator/", accent: "#007cf0" },
  { label: "Decode JWT", href: "/tools/jwt-decoder/", accent: "#f5a623" },
];
---

<section class="hero-shell relative overflow-hidden" id="hero">
  <div class="hero-atmosphere absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div class="hero-grid absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div class="hero-vignette absolute inset-x-0 bottom-0 h-24 pointer-events-none" aria-hidden="true"></div>

  <div class="container-page relative z-10 py-10 md:py-14 lg:py-16 text-center">
    <div class="w-fit mx-auto flex items-center gap-2 mb-5 px-4 py-1.5 bg-canvas-soft rounded-full shadow-card text-xs font-mono text-body">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-success motion-safe:animate-pulse" aria-hidden="true"></span>
      {t('hero.badge')}
    </div>

    <h1 class="text-3xl md:text-5xl lg:text-6xl font-semibold text-ink max-w-3xl mx-auto text-balance" style="line-height: 1.02; letter-spacing: 0;">
      Free Online Tools - Text, Code, Math, SEO &amp;&nbsp;More
    </h1>

    <p class="mt-4 text-base md:text-lg text-body max-w-2xl mx-auto leading-relaxed text-pretty">
      {SITE.description}
    </p>

    <div class="mt-7 max-w-2xl mx-auto">
      <div class="relative">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 text-mute pointer-events-none"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="hero-search"
          type="search"
          placeholder={t('hero.searchPlaceholder')}
          autocomplete="off"
          class="w-full h-12 pl-12 pr-4 bg-canvas border border-hairline rounded-xl text-base text-ink placeholder:text-mute shadow-card focus:shadow-elevated focus:border-link transition-shadow duration-200"
          aria-label={t('hero.searchLabel')}
          role="combobox"
          aria-expanded="false"
          aria-controls="hero-search-results"
          aria-autocomplete="list"
        />
      </div>
      <div id="hero-search-results" class="hidden mt-2 bg-canvas rounded-lg shadow-modal border border-hairline overflow-hidden text-left" role="listbox"></div>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-2" aria-label="Quick tool categories">
        {quickTasks.map((task) => (
          <a href={task.href} class="quick-task" style={`--task-accent: ${task.accent}`}>
            {task.label}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-6 flex items-center justify-center gap-3 flex-wrap">
      <a href="/tools/" class="btn-primary">
        {t('hero.cta')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hero-shell {
    background:
      linear-gradient(180deg, var(--color-canvas) 0%, color-mix(in srgb, var(--color-canvas-soft) 78%, var(--color-canvas)) 100%);
  }

  .hero-atmosphere {
    opacity: 0.92;
    background:
      radial-gradient(circle at 50% 0%, rgba(0, 124, 240, 0.16), transparent 34%),
      radial-gradient(circle at 16% 24%, rgba(0, 223, 216, 0.10), transparent 24%),
      radial-gradient(circle at 84% 26%, rgba(255, 0, 128, 0.08), transparent 25%),
      radial-gradient(circle at 50% 68%, rgba(249, 203, 40, 0.07), transparent 32%);
  }

  .hero-grid {
    opacity: 0.42;
    background-image:
      linear-gradient(color-mix(in srgb, var(--color-ink) 7%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--color-ink) 7%, transparent) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 58%, transparent 88%);
  }

  .hero-vignette {
    background: linear-gradient(180deg, transparent, var(--color-canvas));
  }

  :global(.dark) .hero-shell {
    background:
      linear-gradient(180deg, #080808 0%, var(--color-canvas) 52%, var(--color-canvas-soft) 100%);
  }

  :global(.dark) .hero-atmosphere {
    opacity: 0.76;
    background:
      radial-gradient(circle at 50% 0%, rgba(0, 124, 240, 0.24), transparent 36%),
      radial-gradient(circle at 18% 30%, rgba(0, 223, 216, 0.12), transparent 28%),
      radial-gradient(circle at 82% 28%, rgba(121, 40, 202, 0.16), transparent 30%),
      radial-gradient(circle at 50% 72%, rgba(245, 166, 35, 0.08), transparent 34%);
  }

  :global(.dark) .hero-grid {
    opacity: 0.34;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  }

  :global(.dark) .hero-vignette {
    background: linear-gradient(180deg, transparent, var(--color-canvas));
  }

  .quick-task {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 12px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--task-accent) 8%, var(--color-canvas));
    color: var(--color-ink);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.15s ease, background-color 0.15s ease, transform 0.15s ease;
  }

  .quick-task:hover {
    border-color: var(--task-accent);
    background: color-mix(in srgb, var(--task-accent) 14%, var(--color-canvas));
    transform: translateY(-1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .quick-task:hover {
      transform: none;
    }
  }
</style>

<script>
  import { TOOLS } from "../data/tools";
  import { createSearchResultStatusText } from "../helpers/utils";

  const input = document.getElementById("hero-search") as HTMLInputElement;
  const results = document.getElementById("hero-search-results");
  let activeIndex = -1;
  let activeLinks: HTMLAnchorElement[] = [];

  function clearResults() {
    if (!results) return;
    results.replaceChildren();
    results.classList.add("hidden");
    input?.setAttribute("aria-expanded", "false");
    input?.removeAttribute("aria-activedescendant");
    activeIndex = -1;
    activeLinks = [];
  }

  function setActiveIndex(index: number) {
    activeLinks.forEach((link, i) => {
      const isActive = i === index;
      link.setAttribute("aria-selected", String(isActive));
      link.classList.toggle("bg-canvas-soft-2", isActive);
    });
    activeIndex = index;
    if (activeLinks[index]) {
      input?.setAttribute("aria-activedescendant", activeLinks[index].id);
    } else {
      input?.removeAttribute("aria-activedescendant");
    }
  }

  function renderResults(query: string) {
    if (!results) return;
    const q = query.toLowerCase().trim();
    if (!q) {
      clearResults();
      return;
    }

    const matches = TOOLS.filter(
      (tool) =>
        tool.name.toLowerCase().includes(q) ||
        tool.description.toLowerCase().includes(q) ||
        tool.keywords.some((keyword) => keyword.includes(q))
    ).slice(0, 5);

    results.replaceChildren();

    if (matches.length === 0) {
      const empty = document.createElement("div");
      empty.className = "px-4 py-3 text-sm text-mute";
      empty.textContent = createSearchResultStatusText(q);
      results.append(empty);
      activeLinks = [];
    } else {
      activeLinks = matches.map((tool, index) => {
        const link = document.createElement("a");
        link.href = `/tools/${tool.slug}/`;
        link.id = `hero-search-option-${index}`;
        link.role = "option";
        link.setAttribute("aria-selected", "false");
        link.className = "flex items-center gap-3 px-4 py-3 hover:bg-canvas-soft-2 transition-colors duration-100 no-underline";

        const icon = document.createElement("span");
        icon.className = "text-lg shrink-0";
        icon.textContent = tool.icon;

        const body = document.createElement("div");
        const name = document.createElement("div");
        name.className = "text-sm font-medium text-ink";
        name.textContent = tool.name;
        const description = document.createElement("div");
        description.className = "text-xs text-mute line-clamp-1";
        description.textContent = tool.description;

        body.append(name, description);
        link.append(icon, body);
        return link;
      });
      results.append(...activeLinks);
    }

    results.classList.remove("hidden");
    input?.setAttribute("aria-expanded", "true");
    setActiveIndex(activeLinks.length > 0 ? 0 : -1);
  }

  input?.addEventListener("input", (event) => {
    renderResults((event.target as HTMLInputElement).value);
  });

  document.addEventListener("click", (event) => {
    if (!input?.contains(event.target as Node) && !results?.contains(event.target as Node)) {
      clearResults();
    }
  });

  input?.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      clearResults();
      input.blur();
      return;
    }
    if (results?.classList.contains("hidden") || activeLinks.length === 0) return;
    if (event.key === "ArrowDown") {
      event.preventDefault();
      setActiveIndex((activeIndex + 1) % activeLinks.length);
    } else if (event.key === "ArrowUp") {
      event.preventDefault();
      setActiveIndex((activeIndex - 1 + activeLinks.length) % activeLinks.length);
    } else if (event.key === "Enter" && activeIndex >= 0) {
      event.preventDefault();
      activeLinks[activeIndex].click();
    }
  });
</script>
