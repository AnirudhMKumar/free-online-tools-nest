---
/**
 * Footer — 4-column footer with links to all site sections.
 * Matches DESIGN.md footer component: body-sm text, caption-mono eyebrows.
 */
import { CATEGORIES, TOOLS, SITE } from "../data/tools";
import { useTranslations, getLangFromUrl } from "../i18n/utils";

const currentYear = new Date().getFullYear();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-canvas border-t border-hairline mt-24">
  <div class="container-page py-16">
    <!-- Newsletter Section -->
    <div class="mb-12 pb-12 border-b border-hairline flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div class="max-w-md">
        <h3 class="text-lg font-semibold text-ink mb-2">
          {t('newsletter.title')}
        </h3>
        <p class="text-sm text-body leading-relaxed">
          {t('newsletter.desc')}
        </p>
      </div>
      <div class="w-full md:w-auto">
        <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            id="newsletter-email"
            placeholder={t('newsletter.placeholder')}
            required
            class="px-4 py-2.5 text-sm rounded-lg border border-hairline focus:border-link outline-none bg-canvas text-ink transition-colors sm:w-80"
          />
          <button
            type="submit"
            class="btn-primary btn-sm flex items-center justify-center font-medium cursor-pointer"
          >
            {t('newsletter.button')}
          </button>
        </form>
        <div id="newsletter-success" class="hidden text-sm text-success mt-2 font-medium">
          {t('newsletter.success')}
        </div>
      </div>
    </div>

    <!-- Footer columns -->
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:gap-12">
      <!-- Tools column -->
      <div>
        <h3 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">{t('footer.tools')}</h3>
        <ul class="space-y-2">
          <li>
            <a href="/tools/" class="footer-link">{t('footer.allTools')}</a>
          </li>
          {TOOLS.slice(0, 6).map((tool) => (
            <li>
              <a href={`/tools/${tool.slug}/`} class="footer-link">{tool.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Categories column -->
      <div>
        <h3 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">{t('footer.categories')}</h3>
        <ul class="space-y-2">
          {CATEGORIES.map((cat) => (
            <li>
              <a href={`/categories/${cat.slug}/`} class="footer-link">{cat.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">{t('footer.company')}</h3>
        <ul class="space-y-2">
          <li><a href="/about/" class="footer-link">{t('footer.about')}</a></li>
          <li><a href="/blog/" class="footer-link">{t('footer.blog')}</a></li>
          <li><a href="/contact/" class="footer-link">{t('footer.contact')}</a></li>
          <li><a href="/faq/" class="footer-link">{t('footer.faq')}</a></li>
          <li><a href="/favorites/" class="footer-link">{t('footer.favorites')}</a></li>
        </ul>
      </div>

      <!-- Legal column -->
      <div>
        <h3 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">{t('footer.legal')}</h3>
        <ul class="space-y-2">
          <li><a href="/privacy-policy/" class="footer-link">{t('footer.privacy')}</a></li>
          <li><a href="/terms-and-conditions/" class="footer-link">{t('footer.terms')}</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-mute">
        &copy; {currentYear} {SITE.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <!-- Social links -->
        <a href="https://x.com/openProj3ct" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-ink transition-colors duration-150" aria-label={t('footer.twitter')}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>

        <!-- LaunchBuff badge - switches image source based on dark/light mode -->
        <a href="https://launchbuff.com" target="_blank" rel="noopener noreferrer" title="Featured on LaunchBuff">
          <img src="https://launchbuff.com/badge-featured-light.svg" alt="Featured on LaunchBuff" width="256" height="80" class="badge-light" />
          <img src="https://launchbuff.com/badge-featured-dark.svg" alt="Featured on LaunchBuff" width="256" height="80" class="badge-dark" />
        </a>

        <span class="text-xs text-mute">
          {t('footer.tagline')}
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    font-size: 14px;
    line-height: 20px;
    letter-spacing: -0.28px;
    color: var(--color-body);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-link:hover {
    color: var(--color-ink);
  }

  /* LaunchBuff badge — show light by default, dark when .dark class on html */
  .badge-dark { display: none; }
  .badge-light { display: inline-block; }
  :global(.dark) .badge-dark { display: inline-block; }
  :global(.dark) .badge-light { display: none; }


</style>

<script>
  /**
   * Language switcher — detects current locale from URL and navigates
   * on selection change. All locales have a URL prefix (/en/, /es/, etc.).
   */
  document.addEventListener("DOMContentLoaded", () => {
    // Newsletter form submission mock
    const form = document.getElementById("newsletter-form") as HTMLFormElement | null;
    const successMsg = document.getElementById("newsletter-success");
    if (form && successMsg) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const emailInput = document.getElementById("newsletter-email") as HTMLInputElement | null;
        if (!emailInput || !emailInput.value) return;

        // Mock saving the email to local storage for demonstration
        const email = emailInput.value;
        const subscribers = JSON.parse(localStorage.getItem("newsletter_subscribers") || "[]");
        if (!subscribers.includes(email)) {
          subscribers.push(email);
          localStorage.setItem("newsletter_subscribers", JSON.stringify(subscribers));
        }

        form.reset();
        form.classList.add("hidden");
        successMsg.classList.remove("hidden");

        setTimeout(() => {
          successMsg.classList.add("hidden");
          form.classList.remove("hidden");
        }, 5000);
      });
    }
  });
</script>
