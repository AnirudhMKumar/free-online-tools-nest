---
/**
 * Footer — 4-column footer with links to all site sections.
 * Matches DESIGN.md footer component: body-sm text, caption-mono eyebrows.
 */
import { CATEGORIES, TOOLS, SITE } from "../data/tools";

const currentYear = new Date().getFullYear();
---

<footer class="bg-canvas border-t border-hairline mt-24">
  <div class="container-page py-16">
    <!-- Footer columns -->
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:gap-12">
      <!-- Tools column -->
      <div>
        <h3 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">Tools</h3>
        <ul class="space-y-2">
          <li>
            <a href="/tools/" class="footer-link">All Tools</a>
          </li>
          {TOOLS.slice(0, 6).map((tool) => (
            <li>
              <a href={`/tools/${tool.slug}/`} class="footer-link">{tool.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Categories column -->
      <div>
        <h3 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">Categories</h3>
        <ul class="space-y-2">
          {CATEGORIES.map((cat) => (
            <li>
              <a href={`/categories/${cat.slug}/`} class="footer-link">{cat.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">Company</h3>
        <ul class="space-y-2">
          <li><a href="/about/" class="footer-link">About</a></li>
          <li><a href="/contact/" class="footer-link">Contact</a></li>
          <li><a href="/faq/" class="footer-link">FAQ</a></li>
          <li><a href="/favorites/" class="footer-link">Favorites</a></li>
        </ul>
      </div>

      <!-- Legal column -->
      <div>
        <h3 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">Legal</h3>
        <ul class="space-y-2">
          <li><a href="/privacy-policy/" class="footer-link">Privacy Policy</a></li>
          <li><a href="/terms-and-conditions/" class="footer-link">Terms &amp; Conditions</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-mute">
        &copy; {currentYear} {SITE.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <!-- Social links -->
        <a href="https://github.com/anirudhmuruganandham/freeonlinetoolsnest" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-ink transition-colors duration-150" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="https://x.com/anirudhm_" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-ink transition-colors duration-150" aria-label="X / Twitter">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <span class="text-xs text-mute">
          Free, fast, and private. No sign-up required.
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    font-size: 14px;
    line-height: 20px;
    letter-spacing: -0.28px;
    color: var(--color-body);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-link:hover {
    color: var(--color-ink);
  }
</style>
