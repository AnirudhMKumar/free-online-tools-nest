---
/**
 * CategoryPage — shared shell for individual category landing pages.
 */
interface Props {
  categorySlug: string;
  heading: string;
  locale?: Lang;
  canonicalPath?: string;
  alternatePaths?: Record<string, string>;
}

import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import ToolCard from "./ToolCard.astro";
import CategoryCard from "./CategoryCard.astro";
import { getToolsByCategory, getCategoryBySlug, CATEGORIES, SITE } from "../data/tools";
import { getLocalizedCategories, getLocalizedCategory, getLocalizedToolsByCategory, PUBLISHED_LOCALES } from "../data/localized";
import { defaultLang } from "../i18n/ui";
import type { Lang } from "../i18n/ui";

const { categorySlug, heading, locale = defaultLang, canonicalPath = `/categories/${categorySlug}/`, alternatePaths } = Astro.props;
const localePrefix = locale === defaultLang ? "" : `/${locale}`;
const category = getLocalizedCategory(locale, categorySlug) ?? getCategoryBySlug(categorySlug)!;
const tools = locale === defaultLang ? getToolsByCategory(categorySlug) : getLocalizedToolsByCategory(locale, categorySlug);
const localizedCategories = locale === defaultLang ? CATEGORIES : getLocalizedCategories(locale);
const otherCategories = localizedCategories.filter((c) => c.slug !== categorySlug);
const pageId = `category-${categorySlug}`;
const pageHeading = heading || category.name;
const finalAlternatePaths = alternatePaths || {
  en: `/categories/${categorySlug}/`,
  ...Object.fromEntries(PUBLISHED_LOCALES.map((lang) => [lang, `/${lang}/categories/${categorySlug}/`])),
  "x-default": `/categories/${categorySlug}/`,
};

const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.url}${canonicalPath}`,
  name: category.name,
  description: category.description,
  url: `${SITE.url}${canonicalPath}`,
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
  author: {
    "@type": "Person",
    name: "Free Online Tools Nest Team",
    url: "https://freeonlinetoolsnest.com/about/",
  },
  datePublished: "2026-01-15",
  dateModified: "2026-06-01",
};
---

<Layout
  title={category.metaTitle || `${category.name} — Free Online ${category.name}`}
  description={category.metaDescription || category.description}
  canonicalPath={canonicalPath}
  ogImage={`/og/${category.slug}.png`}
  jsonLd={collectionJsonLd}
  lang={locale}
  alternatePaths={finalAlternatePaths}
>
  <div class="container-page py-8 md:py-10" data-category-page={pageId}>
    <Breadcrumbs items={[{ label: "Categories", href: `${localePrefix}/categories/` }, { label: category.name }]} />

    <header class="app-panel overflow-hidden p-5 sm:p-7 md:p-8 mb-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <div class="mb-4 flex flex-wrap items-center gap-2">
            <span class="metadata-badge"><span aria-hidden="true">{category.icon}</span>{tools.length} tools</span>
            <span class="metadata-badge">Private browser utilities</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-semibold text-ink text-balance" style="letter-spacing: 0; line-height: 1.08;">
            {pageHeading}
          </h1>
          <p class="mt-3 text-body text-base md:text-lg max-w-2xl leading-relaxed text-pretty">
            {category.description}
          </p>
        </div>

        <div class="control-shell w-full lg:w-[360px] p-3">
          <label for={`${pageId}-search`} class="sr-only">Filter {category.name}</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-mute pointer-events-none" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              id={`${pageId}-search`}
              type="search"
              name="category-search"
              autocomplete="off"
              placeholder={`Search ${category.name.toLowerCase()}…`}
              class="w-full h-11 pl-10 pr-4 rounded-lg border border-hairline bg-canvas text-sm text-ink placeholder:text-mute focus:border-link transition-colors duration-150"
              data-category-search
            />
          </div>
          <p class="mt-2 text-xs text-mute" aria-live="polite" data-category-count>
            Showing {tools.length} {tools.length === 1 ? "tool" : "tools"}
          </p>
        </div>
      </div>
    </header>

    <nav class="mb-8 flex gap-2 overflow-x-auto pb-2" aria-label="Browse categories">
      <a href={`${localePrefix}/tools/`} class="pill-control">All tools</a>
      {localizedCategories.map((cat) => (
        <a href={`${localePrefix}/categories/${cat.slug}/`} class="pill-control" aria-current={cat.slug === categorySlug ? "page" : undefined}>
          <span aria-hidden="true">{cat.icon}</span> {cat.name}
        </a>
      ))}
    </nav>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-14" data-category-grid>
      {tools.map((tool) => (
        <div data-category-tool data-tool-name={tool.name.toLowerCase()} data-tool-desc={tool.description.toLowerCase()} data-tool-keywords={tool.keywords.join(" ").toLowerCase()}>
          <ToolCard slug={tool.slug} href={`${localePrefix}/tools/${tool.slug}/`} name={tool.name} description={tool.description} icon={tool.icon} categorySlug={tool.categorySlug} categoryName={category.name} />
        </div>
      ))}
    </div>

    <div class="hidden rounded-lg border border-hairline bg-canvas p-8 text-center mb-14" data-category-empty>
      <p class="text-base font-medium text-ink">No tools match that search.</p>
      <p class="mt-1 text-sm text-body">Try a shorter term or browse another category.</p>
    </div>

    <section class="mb-14">
      <div class="section-heading">
        <div>
          <p class="section-eyebrow">More utility groups</p>
          <h2 class="section-title">Explore other categories</h2>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {otherCategories.map((cat) => (
          <CategoryCard
            slug={cat.slug}
            href={`${localePrefix}/categories/${cat.slug}/`}
            name={cat.name}
            description={cat.description}
            icon={cat.icon}
            color={cat.color}
            toolCount={locale === defaultLang ? getToolsByCategory(cat.slug).length : getLocalizedToolsByCategory(locale, cat.slug).length}
            topTools={(locale === defaultLang ? getToolsByCategory(cat.slug) : getLocalizedToolsByCategory(locale, cat.slug)).slice(0, 3).map((tool) => tool.name)}
          />
        ))}
      </div>
    </section>

    {category.seoContent && (
      <section class="mt-14 border-t border-hairline pt-10">
        <div class="prose-like max-w-3xl">
          <p class="section-eyebrow">Category guide</p>
          <h2 class="text-xl font-semibold text-ink mb-4" style="letter-spacing: 0;">
            About our {category.name}
          </h2>
          <p class="text-body leading-relaxed">{category.seoContent}</p>
        </div>
      </section>
    )}
  </div>
</Layout>

<script>
  const pages = document.querySelectorAll<HTMLElement>("[data-category-page]");
  pages.forEach((page) => {
    const input = page.querySelector<HTMLInputElement>("[data-category-search]");
    const items = Array.from(page.querySelectorAll<HTMLElement>("[data-category-tool]"));
    const count = page.querySelector<HTMLElement>("[data-category-count]");
    const empty = page.querySelector<HTMLElement>("[data-category-empty]");

    function filterCategoryTools() {
      const query = input?.value.toLowerCase().trim() || "";
      let visible = 0;
      items.forEach((item) => {
        const haystack = [item.dataset.toolName, item.dataset.toolDesc, item.dataset.toolKeywords].join(" ");
        const show = !query || haystack.includes(query);
        item.hidden = !show;
        if (show) visible++;
      });
      if (count) count.textContent = `Showing ${visible} ${visible === 1 ? "tool" : "tools"}`;
      empty?.classList.toggle("hidden", visible > 0);
    }

    input?.addEventListener("input", filterCategoryTools);
  });
</script>
