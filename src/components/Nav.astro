---
/**
 * Nav — sticky navigation bar.
 * Logo left, category links center, dark mode toggle right.
 * Mobile: hamburger menu with full-screen overlay.
 */
import { CATEGORIES, SITE } from "../data/tools";
import { useTranslations, getLangFromUrl } from "../i18n/utils";
import { defaultLang } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const localePrefix = lang === defaultLang ? "" : `/${lang}`;

// locale-aware href helper: prepend locale unless it's a non-localized root page
const lh = (path: string) => `${localePrefix}${path}`;
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 bg-canvas/80 backdrop-blur-lg border-b border-hairline"
  style="height: 64px;"
>
  <nav class="container-page flex items-center justify-between h-full" aria-label={t('nav.mainNav')}>
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 no-underline group" aria-label={`${SITE.name} ${t('nav.homeLabel')}`}>
      <span class="text-base sm:text-lg font-semibold tracking-tight text-ink" style="letter-spacing: -0.6px;">
        FreeOnlineToolsNest
      </span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-1">
      <a href="/tools/" class="nav-link">{t('nav.tools')}</a>
      <a href="/blog/" class="nav-link">{t('nav.blog')}</a>
      {CATEGORIES.map((cat) => (
        <a href={`/categories/${cat.slug}/`} class="nav-link">
          {cat.name}
        </a>
      ))}
    </div>

    <!-- Right cluster -->
    <div class="flex items-center gap-2">
      <!-- Search button (opens ⌘K search) -->
      <button
        id="cmd-k-trigger"
        type="button"
        class="relative p-2 rounded-full text-mute hover:text-ink hover:bg-canvas-soft-2 transition-colors duration-150 cursor-pointer"
        aria-label={t('nav.search')}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <kbd class="absolute -bottom-0.5 -right-0.5 text-[9px] font-mono text-mute bg-canvas-soft-2 px-0.5 rounded border border-hairline leading-none" aria-hidden="true">⌘K</kbd>
      </button>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        type="button"
        class="p-2 rounded-full text-mute hover:text-ink hover:bg-canvas-soft-2 transition-colors duration-150"
        aria-label={t('nav.theme')}
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="sun-icon hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden p-2 rounded-full text-mute hover:text-ink hover:bg-canvas-soft-2 transition-colors duration-150"
        aria-label={t('nav.menu')}
        aria-expanded="false"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-canvas hidden flex-col pt-20 px-6 pb-6 md:hidden"
  role="dialog"
  aria-modal="true"
    aria-label={t('nav.mobileNav')}
>
  <button
    id="mobile-menu-close"
    type="button"
    class="absolute top-5 right-6 p-2 rounded-full text-mute hover:text-ink"
    aria-label={t('nav.closeMenu')}
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <nav class="flex flex-col gap-1" aria-label={t('nav.mobileNav')}>
    <a href="/tools/" class="mobile-nav-link">{t('nav.tools')}</a>
    <a href="/blog/" class="mobile-nav-link">{t('nav.blog')}</a>
    {CATEGORIES.map((cat) => (
      <a href={`/categories/${cat.slug}/`} class="mobile-nav-link">
        <span class="mr-2">{cat.icon}</span> {cat.name}
      </a>
    ))}
    <hr class="my-4 border-hairline" />
    <a href={lh('/about/')} class="mobile-nav-link">{t('nav.about')}</a>
    <a href={lh('/contact/')} class="mobile-nav-link">{t('nav.contact')}</a>
    <a href={lh('/faq/')} class="mobile-nav-link">{t('nav.faq')}</a>
  </nav>
</div>

<!-- Spacer for fixed nav -->
<div style="height: 64px;" aria-hidden="true"></div>

<style>
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: -0.28px;
    color: var(--color-body);
    border-radius: var(--radius-full);
    transition: color 0.15s ease, background-color 0.15s ease;
    text-decoration: none;
  }
  .nav-link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft-2);
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    font-size: 16px;
    font-weight: 500;
    color: var(--color-ink);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .mobile-nav-link:hover {
    background-color: var(--color-canvas-soft-2);
  }

  /* Dark mode icon visibility */
  .dark .sun-icon { display: block; }
  .dark .moon-icon { display: none; }
</style>

<script>
  // Dark mode toggle
  function initTheme() {
    const toggle = document.getElementById("theme-toggle");
    const html = document.documentElement;

    // Check saved preference or system preference
    const saved = localStorage.getItem("theme");
    if (saved === "dark" || (!saved && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
      html.classList.add("dark");
    }

    toggle?.addEventListener("click", () => {
      html.classList.toggle("dark");
      localStorage.setItem("theme", html.classList.contains("dark") ? "dark" : "light");
    });
  }

  // Mobile menu
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("mobile-menu-close");
    const menu = document.getElementById("mobile-menu");

    function openMenu() {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
      btn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      btn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }

    btn?.addEventListener("click", openMenu);
    closeBtn?.addEventListener("click", closeMenu);

    // Close on escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !menu?.classList.contains("hidden")) {
        closeMenu();
      }
    });
  }

  initTheme();
  initMobileMenu();
</script>
