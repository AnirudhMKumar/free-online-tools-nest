---
/**
 * AsSeenOn — social proof section for homepage.
 * Shows logos/media mentions to build credibility.
 */
---

<section class="py-12 md:py-16 border-y" style="border-color: var(--color-hairline);">
  <div class="container-page text-center">
    <p class="text-xs font-mono uppercase tracking-wider mb-6" style="color: var(--color-mute);">
      Trusted by users worldwide
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 opacity-50">
      <!-- Placeholder logos — replace with actual media mentions when available -->
      <span class="text-sm font-semibold" style="color: var(--color-mute); font-family: var(--font-mono);">
        Product Hunt
      </span>
      <span class="text-sm font-semibold" style="color: var(--color-mute); font-family: var(--font-mono);">
        BetaList
      </span>
      <span class="text-sm font-semibold" style="color: var(--color-mute); font-family: var(--font-mono);">
        Hacker News
      </span>
      <span class="text-sm font-semibold" style="color: var(--color-mute); font-family: var(--font-mono);">
        GitHub
      </span>
    </div>
  </div>
</section>
