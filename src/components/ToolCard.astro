---
/**
 * ToolCard — dense, premium card linking to a tool page.
 * Used in grids on the homepage, directory, category, favorites, and related tools surfaces.
 */
interface Props {
  slug: string;
  name: string;
  description: string;
  icon: string;
  categorySlug: string;
  variant?: "default" | "compact";
}

import { getCategoryBySlug } from "../data/tools";

const { slug, name, description, icon, categorySlug, variant = "default" } = Astro.props;
const category = getCategoryBySlug(categorySlug);
const isCompact = variant === "compact";
const cardClass = isCompact ? "tool-card tool-card-compact group" : "tool-card group";
---

<a href={`/tools/${slug}/`} class={cardClass} id={`tool-${slug}`}>
  <span class="tool-card-icon" aria-hidden="true">{icon}</span>
  <span class="tool-card-body">
    <span class="tool-card-title-row">
      <span class="tool-card-title">{name}</span>
      <svg class="tool-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </span>
    <span class="tool-card-description">{description}</span>
    {category && !isCompact && (
      <span class="metadata-badge mt-auto w-fit">{category.name}</span>
    )}
  </span>
</a>
