---
/**
 * ToolCard — card linking to a tool page.
 * Used in grids on the homepage, directory, and category pages.
 */
interface Props {
  slug: string;
  name: string;
  description: string;
  icon: string;
  categorySlug: string;
}

import { getCategoryBySlug } from "../data/tools";

const { slug, name, description, icon, categorySlug } = Astro.props;
const category = getCategoryBySlug(categorySlug);
---

<a
  href={`/tools/${slug}/`}
  class="block card p-4 sm:p-6 hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-200 no-underline group"
  id={`tool-${slug}`}
>
  <div class="flex items-start gap-4">
    <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">{icon}</span>
    <div class="min-w-0">
      <h3 class="text-base font-medium text-ink group-hover:text-link transition-colors duration-150" style="letter-spacing: -0.28px;">
        {name}
      </h3>
      <p class="mt-1 text-sm text-body leading-relaxed line-clamp-2">
        {description}
      </p>
      {category && (
        <span class="inline-block mt-3 text-xs text-mute bg-canvas-soft-2 px-2 py-0.5 rounded-full">
          {category.name}
        </span>
      )}
    </div>
  </div>
</a>
