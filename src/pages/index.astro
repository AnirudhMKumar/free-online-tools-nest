---
/**
 * Root index — redirects to the English locale homepage.
 * Language detection from browser is handled client-side via JS redirect.
 */
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Free Online Tools Nest</title>
  <meta http-equiv="refresh" content="0;url=/en/" />
  <script is:inline>
    // Client-side browser language redirect
    (function() {
      var lang = (navigator.language || navigator.languages?.[0] || '').slice(0, 2);
      var supported = ['es', 'pt', 'fr', 'de', 'hi', 'ja', 'ar'];
      window.location.href = '/' + (supported.includes(lang) ? lang : 'en') + '/';
    })();
  </script>
</head>
<body>
  <a href="/en/">Free Online Tools Nest</a>
</body>
</html>
