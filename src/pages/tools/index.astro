---
/**
 * Tools Directory — all tools in a filterable grid.
 */
import Layout from "../../layouts/Layout.astro";
import { getDefaultAlternates } from "../../i18n/utils";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ToolCard from "../../components/ToolCard.astro";
import { TOOLS, CATEGORIES, SITE, getToolsByCategory } from "../../data/tools";

const toolsCollectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.url}/tools/`,
  name: "All Free Online Tools — Directory & Utilities",
  description: `Explore our comprehensive web tools collection of ${TOOLS.length} free online tools.`,
  url: `${SITE.url}/tools/`,
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
};
---

<Layout
  title="All Free Online Tools — Directory & Utilities"
  description={`Explore our comprehensive web tools collection of ${TOOLS.length} free online tools. Access browser-based utilities for text formatting, developer tasks, math, and converters.`}
  canonicalPath="/tools/"
  alternatePaths={getDefaultAlternates("/tools/")}
  ogImage="/og-default.png"
  jsonLd={toolsCollectionJsonLd}
>
  <div class="container-page py-8 md:py-10">
    <Breadcrumbs items={[{ label: "All Tools" }]} />

    <header class="app-panel p-5 sm:p-7 md:p-8 mb-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <div class="mb-4 flex flex-wrap gap-2">
            <span class="metadata-badge">{TOOLS.length} tools</span>
            <span class="metadata-badge">No uploads</span>
            <span class="metadata-badge">No signup</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-semibold text-ink text-balance" style="letter-spacing: 0; line-height: 1.08;">
            All Free Online Tools
          </h1>
          <p class="mt-3 text-body text-base md:text-lg max-w-2xl leading-relaxed text-pretty">
            Search the full library of browser-based utilities for text, code, PDFs, images, SEO, math, and design.
          </p>
        </div>

        <div class="control-shell w-full lg:w-[420px] p-3">
          <label for="tools-search" class="sr-only">Filter tools</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-mute pointer-events-none" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              id="tools-search"
              type="search"
              name="tools-search"
              placeholder="Filter tools…"
              autocomplete="off"
              class="w-full h-11 pl-10 pr-4 border border-hairline rounded-lg bg-canvas text-sm text-ink placeholder:text-mute focus:border-link transition-colors duration-150"
              aria-label="Filter tools"
            />
          </div>
          <p id="tools-result-count" class="mt-2 text-xs text-mute" aria-live="polite">Showing {TOOLS.length} tools</p>
        </div>
      </div>
    </header>

    <div class="mb-8 flex gap-2 overflow-x-auto pb-2" id="category-filters" role="group" aria-label="Filter by category">
      <button type="button" data-filter="all" class="filter-tab active" aria-pressed="true">All</button>
      {CATEGORIES.map((cat) => (
        <button type="button" data-filter={cat.slug} class="filter-tab" aria-pressed="false">
          <span aria-hidden="true">{cat.icon}</span> {cat.name}
          <span class="filter-count">{getToolsByCategory(cat.slug).length}</span>
        </button>
      ))}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="tools-grid">
      {TOOLS.map((tool) => (
        <div data-category={tool.categorySlug} data-name={tool.name.toLowerCase()} data-desc={tool.description.toLowerCase()} data-keywords={tool.keywords.join(" ").toLowerCase()}>
          <ToolCard slug={tool.slug} name={tool.name} description={tool.description} icon={tool.icon} categorySlug={tool.categorySlug} />
        </div>
      ))}
    </div>

    <div id="no-results" class="hidden rounded-lg border border-hairline bg-canvas p-10 text-center mt-8">
      <p class="text-base font-medium text-ink">No tools match your search.</p>
      <p class="mt-1 text-sm text-body">Try a broader keyword or switch category filters.</p>
    </div>
  </div>
</Layout>

<style>
  .filter-tab {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 38px;
    padding: 0 13px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    background-color: var(--color-canvas);
    color: var(--color-body);
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .filter-tab:hover {
    border-color: var(--color-hairline-strong);
    color: var(--color-ink);
  }
  .filter-tab.active {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
  }
  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, currentColor 10%, transparent);
    font-size: 12px;
  }
</style>

<script>
  const grid = document.getElementById("tools-grid");
  const search = document.getElementById("tools-search") as HTMLInputElement;
  const noResults = document.getElementById("no-results");
  const resultCount = document.getElementById("tools-result-count");
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-tab");

  let activeCategory = "all";

  function filterTools() {
    if (!grid) return;
    const query = search?.value.toLowerCase().trim() || "";
    const items = grid.querySelectorAll<HTMLElement>("[data-category]");
    let visible = 0;

    items.forEach((item) => {
      const cat = item.dataset.category || "";
      const haystack = [item.dataset.name, item.dataset.desc, item.dataset.keywords].join(" ");
      const matchesCategory = activeCategory === "all" || cat === activeCategory;
      const matchesSearch = !query || haystack.includes(query);
      item.hidden = !(matchesCategory && matchesSearch);
      if (!item.hidden) visible++;
    });

    noResults?.classList.toggle("hidden", visible > 0);
    if (resultCount) resultCount.textContent = `Showing ${visible} ${visible === 1 ? "tool" : "tools"}`;
  }

  search?.addEventListener("input", filterTools);

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-pressed", "true");
      activeCategory = btn.dataset.filter || "all";
      filterTools();
    });
  });
</script>
