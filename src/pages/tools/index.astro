---
/**
 * Tools Directory — all tools in a filterable grid.
 */
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ToolCard from "../../components/ToolCard.astro";
import { TOOLS, CATEGORIES, SITE } from "../../data/tools";
---

<Layout
  title="All-in-One Web Tools Collection — Free Online Tools Directory"
  description={`Explore our comprehensive web tools collection of ${TOOLS.length} free online tools. Access browser-based utilities for text formatting, developer tasks, math, and converters.`}
  canonicalPath="/tools/"
>
  <div class="container-page py-8 md:py-12">
    <Breadcrumbs items={[{ label: "All Tools" }]} />

    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-semibold text-ink" style="letter-spacing: -1.28px;">
        All Free Online Tools
      </h1>
      <p class="mt-3 text-body text-lg max-w-xl">
        {TOOLS.length} free tools — pick one and get started.
      </p>
    </header>

    <!-- Search -->
    <div class="mb-8 max-w-md">
      <div class="relative">
        <svg
          class="absolute left-3 top-1/2 -translate-y-1/2 text-mute pointer-events-none"
          width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="tools-search"
          type="search"
          placeholder="Filter tools…"
          autocomplete="off"
          class="w-full h-10 pl-10 pr-4 border rounded-lg text-sm outline-none transition-colors duration-150"
          style="background-color: var(--color-canvas); border-color: var(--color-hairline); color: var(--color-ink);"
          aria-label="Filter tools"
        />
      </div>
    </div>

    <!-- Category filter tabs -->
    <div class="flex flex-wrap gap-2 mb-8" id="category-filters">
      <button
        type="button"
        data-filter="all"
        class="filter-tab active px-3 py-1.5 text-sm rounded-full border transition-all duration-150"
      >
        All
      </button>
      {CATEGORIES.map((cat) => (
        <button
          type="button"
          data-filter={cat.slug}
          class="filter-tab px-3 py-1.5 text-sm rounded-full border transition-all duration-150"
        >
          {cat.icon} {cat.name}
        </button>
      ))}
    </div>

    <!-- Tools grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="tools-grid">
      {TOOLS.map((tool) => (
        <div data-category={tool.categorySlug} data-name={tool.name.toLowerCase()} data-desc={tool.description.toLowerCase()}>
          <ToolCard
            slug={tool.slug}
            name={tool.name}
            description={tool.description}
            icon={tool.icon}
            categorySlug={tool.categorySlug}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-results" class="hidden text-center py-12">
      <p class="text-lg text-mute">No tools match your search.</p>
    </div>
  </div>
</Layout>

<style>
  .filter-tab {
    background-color: var(--color-canvas);
    color: var(--color-body);
    border-color: var(--color-hairline);
  }
  .filter-tab:hover {
    border-color: var(--color-hairline-strong);
    color: var(--color-ink);
  }
  .filter-tab.active {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
  }
</style>

<script>
  // Client-side filtering
  const grid = document.getElementById("tools-grid");
  const search = document.getElementById("tools-search") as HTMLInputElement;
  const noResults = document.getElementById("no-results");
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-tab");

  let activeCategory = "all";

  function filterTools() {
    if (!grid) return;
    const query = search?.value.toLowerCase().trim() || "";
    const items = grid.querySelectorAll<HTMLElement>("[data-category]");
    let visible = 0;

    items.forEach((item) => {
      const cat = item.dataset.category || "";
      const name = item.dataset.name || "";
      const desc = item.dataset.desc || "";

      const matchesCategory = activeCategory === "all" || cat === activeCategory;
      const matchesSearch = !query || name.includes(query) || desc.includes(query);

      if (matchesCategory && matchesSearch) {
        item.style.display = "";
        visible++;
      } else {
        item.style.display = "none";
      }
    });

    if (noResults) {
      noResults.classList.toggle("hidden", visible > 0);
    }
  }

  search?.addEventListener("input", filterTools);

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeCategory = btn.dataset.filter || "all";
      filterTools();
    });
  });
</script>
