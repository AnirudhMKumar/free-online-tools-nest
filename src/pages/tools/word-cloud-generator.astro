---
import ToolLayout from "../../layouts/ToolLayout.astro";
import WordCloudGenerator from "../../components/tools/WordCloudGenerator";
import { getToolBySlug, getCategoryBySlug } from "../../data/tools";

const tool = getToolBySlug("word-cloud-generator")!;
const category = getCategoryBySlug(tool.categorySlug)!;
---

<ToolLayout
  title={tool.name}
  description={tool.description}
  toolSlug={tool.slug}
  categorySlug={tool.categorySlug}
  categoryName={category.name}
  longDescription={tool.longDescription}
  keywords={tool.keywords}
>
  <WordCloudGenerator client:load />
</ToolLayout>
