---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ToolCard from "../../components/ToolCard.astro";
import { getToolsByCategory, getCategoryBySlug, CATEGORIES, SITE } from "../../data/tools";

const category = getCategoryBySlug("pdf-tools")!;
const tools = getToolsByCategory("pdf-tools");
const otherCategories = CATEGORIES.filter((c) => c.slug !== "pdf-tools");

const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.url}/categories/${category.slug}/`,
  name: category.name,
  description: category.description,
  url: `${SITE.url}/categories/${category.slug}/`,
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
  author: {
    "@type": "Person",
    name: "Free Online Tools Nest Team",
    url: "https://freeonlinetoolsnest.com/about/",
  },
  datePublished: "2026-01-15",
  dateModified: "2026-06-01",
};
---

<Layout
  title={category.metaTitle || `${category.name} — Free Online ${category.name}`}
  description={category.metaDescription || category.description}
  canonicalPath={`/categories/${category.slug}/`}
  ogImage={`/og/${category.slug}.png`}
  jsonLd={collectionJsonLd}
>
  <div class="container-page py-8 md:py-12">
    <Breadcrumbs items={[{ label: "Categories", href: "/categories/" }, { label: category.name }]} />

    <header class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-3xl" aria-hidden="true">{category.icon}</span>
        <h1 class="text-3xl md:text-4xl font-semibold text-ink" style="letter-spacing: -1.28px;">
          Free Online PDF Tools
        </h1>
      </div>
      <p class="mt-3 text-body text-lg max-w-2xl">{category.description}</p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      {tools.map((tool) => (
        <ToolCard slug={tool.slug} name={tool.name} description={tool.description} icon={tool.icon} categorySlug={tool.categorySlug} />
      ))}
    </div>

    <section class="mb-16">
      <h2 class="text-xl font-semibold text-ink mb-6" style="letter-spacing: -0.6px;">Explore other categories</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {otherCategories.map((cat) => (
          <a href={`/categories/${cat.slug}/`} class="card p-4 flex items-center gap-3 hover:shadow-card-hover transition-all duration-200 no-underline">
            <span class="text-2xl" aria-hidden="true">{cat.icon}</span>
            <div>
              <span class="text-sm font-medium text-ink">{cat.name}</span>
              <span class="block text-xs text-mute">{getToolsByCategory(cat.slug).length} tools</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    {category.seoContent && (
      <section class="mt-16 border-t border-hairline pt-12">
        <div class="prose-like max-w-3xl">
          <h2 class="text-xl font-semibold text-ink mb-4" style="letter-spacing: -0.6px;">
            About our {category.name}
          </h2>
          <p class="text-body leading-relaxed">{category.seoContent}</p>
        </div>
      </section>
    )}
  </div>
</Layout>
