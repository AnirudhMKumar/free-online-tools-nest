---
/**
 * Categories Directory — all 7 categories in a polished grid.
 */
import Layout from "../../layouts/Layout.astro";
import { getDefaultAlternates } from "../../i18n/utils";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import { CATEGORIES, getToolsByCategory, SITE } from "../../data/tools";

const categoriesJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.url}/categories/`,
  name: "All Tool Categories — Free Online Tools Nest",
  description: `Browse all ${CATEGORIES.length} categories of free online tools.`,
  url: `${SITE.url}/categories/`,
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
};
---

<Layout
  title="All Tool Categories — Browse Free Online Tools by Category"
  description={`Browse all ${CATEGORIES.length} categories of free online tools. Find text tools, developer utilities, calculators, converters, PDF tools, SEO tools, and design tools.`}
  canonicalPath="/categories/"
  alternatePaths={getDefaultAlternates("/categories/")}
  ogImage="/og-default.png"
  jsonLd={categoriesJsonLd}
>
  <div class="container-page py-8 md:py-10">
    <Breadcrumbs items={[{ label: "Categories" }]} />

    <header class="app-panel p-5 sm:p-7 md:p-8 mb-8">
      <div class="section-heading mb-0">
        <div>
          <p class="section-eyebrow">{CATEGORIES.length} utility groups</p>
          <h1 class="text-3xl md:text-4xl font-semibold text-ink text-balance" style="letter-spacing: 0; line-height: 1.08;">
            Browse Tools by Category
          </h1>
          <p class="section-description">
            Find the right browser-based utility for writing, coding, PDFs, images, SEO, math, and design work.
          </p>
        </div>
        <a href="/tools/" class="pill-control">All 77 tools</a>
      </div>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {CATEGORIES.map((cat) => (
        <CategoryCard
          slug={cat.slug}
          name={cat.name}
          description={cat.description}
          icon={cat.icon}
          color={cat.color}
          toolCount={getToolsByCategory(cat.slug).length}
          topTools={getToolsByCategory(cat.slug).slice(0, 3).map((tool) => tool.name)}
        />
      ))}
    </div>
  </div>
</Layout>
