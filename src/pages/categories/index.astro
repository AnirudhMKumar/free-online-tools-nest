---
/**
 * Categories Directory — all 7 categories in a grid.
 */
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import { CATEGORIES, getToolsByCategory, SITE } from "../../data/tools";

const categoriesJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.url}/categories/`,
  name: "All Tool Categories — Free Online Tools Nest",
  description: `Browse all ${CATEGORIES.length} categories of free online tools.`,
  url: `${SITE.url}/categories/`,
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
};
---

<Layout
  title="All Tool Categories — Browse Free Online Tools by Category"
  description={`Browse all ${CATEGORIES.length} categories of free online tools. Find text tools, developer utilities, calculators, converters, PDF tools, SEO tools, and design tools.`}
  canonicalPath="/categories/"
  ogImage="/og-default.png"
  jsonLd={categoriesJsonLd}
>
  <div class="container-page py-8 md:py-12">
    <Breadcrumbs items={[{ label: "Categories" }]} />

    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-semibold text-ink" style="letter-spacing: -1.28px;">
        Browse Tools by Category
      </h1>
      <p class="mt-3 text-body text-lg max-w-xl">
        {CATEGORIES.length} categories — find the right tool for any task.
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {CATEGORIES.map((cat) => (
        <CategoryCard
          slug={cat.slug}
          name={cat.name}
          description={cat.description}
          icon={cat.icon}
          color={cat.color}
          toolCount={getToolsByCategory(cat.slug).length}
        />
      ))}
    </div>
  </div>
</Layout>
