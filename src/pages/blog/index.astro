---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { SITE } from "../../data/tools";

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": `${SITE.url}/blog/`,
  name: "Blog — Free Online Tools Nest | Tips & Updates",
  description: "Read about the latest free online tools, productivity tips, and web development insights.",
  url: `${SITE.url}/blog/`,
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
};
---

<Layout
  title="Blog — Free Online Tools Nest | Tips & Updates"
  description="Read about the latest free online tools, productivity tips, and web development insights."
  canonicalPath="/blog/"
  ogImage="/og-default.png"
  jsonLd={blogJsonLd}
>
  <div class="container-narrow py-12">
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-semibold text-ink" style="letter-spacing: -1.28px;">
        Blog
      </h1>
      <p class="mt-3 text-body text-lg">
        Tips, updates, and guides for getting the most out of Free Online Tools Nest.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="text-mute">No posts yet. Check back soon!</p>
    ) : (
      <div class="space-y-8">
        {posts.map((post) => (
          <article class="card p-6 hover:shadow-card-hover transition-shadow duration-200">
            <a href={`/blog/${post.id}/`} class="no-underline group">
              <h2 class="text-xl font-semibold text-ink group-hover:text-link transition-colors duration-150">
                {post.data.title}
              </h2>
              <p class="mt-2 text-body leading-relaxed">
                {post.data.description}
              </p>
              <div class="mt-4 flex items-center gap-3 text-xs text-mute">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric", month: "long", day: "numeric",
                  })}
                </time>
                {post.data.tags.length > 0 && (
                  <span>
                    {post.data.tags.map(t => `#${t}`).join(" ")}
                  </span>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>
