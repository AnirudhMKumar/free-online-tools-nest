---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../data/tools";
---

<Layout
  title="Contact Us — Free Online Tools Nest"
  description="Have a suggestion, feedback, or need to report a bug? Get in touch with the Free Online Tools Nest team. We'd love to hear from you."
  canonicalPath="/contact/"
>
  <div class="container-narrow py-12 md:py-20">
    <h1 class="text-3xl md:text-4xl font-semibold text-ink mb-3" style="letter-spacing: -1.28px;">
      Contact us
    </h1>
    <p class="text-body text-lg mb-10">
      Have feedback, a tool suggestion, or found a bug? We would love to hear from you.
    </p>

    <form
      action="https://formspree.io/f/placeholder"
      method="POST"
      class="space-y-6 card p-4 sm:p-6 md:p-8"
      id="contact-form"
    >
      <div>
        <label for="contact-name" class="block text-sm font-medium text-ink mb-2">
          Name
        </label>
        <input
          id="contact-name"
          name="name"
          type="text"
          required
          autocomplete="name"
          placeholder="Your name…"
          class="w-full h-11 px-4 border rounded-md text-sm outline-none transition-colors duration-150"
          style="background-color: var(--color-canvas-soft); border-color: var(--color-hairline); color: var(--color-ink);"
        />
      </div>

      <div>
        <label for="contact-email" class="block text-sm font-medium text-ink mb-2">
          Email
        </label>
        <input
          id="contact-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@example.com…"
          spellcheck="false"
          class="w-full h-11 px-4 border rounded-md text-sm outline-none transition-colors duration-150"
          style="background-color: var(--color-canvas-soft); border-color: var(--color-hairline); color: var(--color-ink);"
        />
      </div>

      <div>
        <label for="contact-subject" class="block text-sm font-medium text-ink mb-2">
          Subject
        </label>
        <select
          id="contact-subject"
          name="subject"
          required
          class="w-full h-11 px-4 border rounded-md text-sm outline-none transition-colors duration-150"
          style="background-color: var(--color-canvas-soft); border-color: var(--color-hairline); color: var(--color-ink);"
        >
          <option value="">Select a subject…</option>
          <option value="feedback">General feedback</option>
          <option value="suggestion">Tool suggestion</option>
          <option value="bug">Report a bug</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div>
        <label for="contact-message" class="block text-sm font-medium text-ink mb-2">
          Message
        </label>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="5"
          placeholder="Tell us what you think…"
          class="w-full p-4 border rounded-md text-sm resize-y outline-none transition-colors duration-150"
          style="background-color: var(--color-canvas-soft); border-color: var(--color-hairline); color: var(--color-ink);"
        ></textarea>
      </div>

      <button
        type="submit"
        class="btn-primary"
        style="background-color: var(--color-primary); color: var(--color-on-primary);"
      >
        Send message
      </button>

      <p class="text-xs text-mute">
        We typically respond within 1–2 business days. Your email will only be used to reply to your message.
      </p>
    </form>
  </div>
</Layout>
