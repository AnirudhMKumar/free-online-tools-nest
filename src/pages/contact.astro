---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../data/tools";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("en");

const webPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${SITE.url}/contact/`,
  name: t("contact.metaTitle"),
  description: t("contact.metaDesc"),
  url: `${SITE.url}/contact/`,
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
};
---

<Layout
  title={t("contact.metaTitle")}
  description={t("contact.metaDesc")}
  canonicalPath="/contact/"
  jsonLd={webPageJsonLd}
>
  <div class="container-narrow py-12 md:py-20">
    <h1 class="text-3xl md:text-4xl font-semibold text-ink mb-3" style="letter-spacing: -1.28px;">
      {t("contact.title")}
    </h1>
    <p class="text-body text-lg mb-10">
      {t("contact.subtitle")}
    </p>

    <section>
      <h2 class="text-xl font-semibold text-ink mb-4" style="letter-spacing: -0.6px;">How can I contact Free Online Tools Nest?</h2>
      <div class="card p-4 sm:p-6 md:p-8 space-y-6">
      <p class="text-body text-sm leading-relaxed">
        {t("contact.emailText")}{" "}
        <a href="mailto:openprojects50@gmail.com" class="text-link hover:text-link-deep underline transition-colors duration-150">
          openprojects50@gmail.com
        </a>
        {" "}{t("contact.responseTime")}
      </p>
      <p class="text-body text-sm leading-relaxed">
        {t("contact.helpText")}
      </p>
      <a
        href="mailto:openprojects50@gmail.com?subject=Feedback%20for%20Free%20Online%20Tools%20Nest"
        class="btn-primary inline-flex"
        style="background-color: var(--color-primary); color: var(--color-on-primary); text-decoration: none;"
      >
        {t("contact.cta")}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
    </div>
    </section>
  </div>
</Layout>
