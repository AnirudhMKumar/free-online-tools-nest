---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../data/tools";
---

<Layout
  title="Contact Us — Free Online Tools Nest"
  description="Have a suggestion, feedback, or need to report a bug? Get in touch with the Free Online Tools Nest team. We'd love to hear from you."
  canonicalPath="/contact/"
>
  <div class="container-narrow py-12 md:py-20">
    <h1 class="text-3xl md:text-4xl font-semibold text-ink mb-3" style="letter-spacing: -1.28px;">
      Contact us
    </h1>
    <p class="text-body text-lg mb-10">
      Have feedback, a tool suggestion, or found a bug? We would love to hear from you.
    </p>

    <div class="card p-4 sm:p-6 md:p-8 space-y-6">
      <p class="text-body text-sm leading-relaxed">
        Send us an email at{" "}
        <a href="mailto:openprojects50@gmail.com" class="text-link hover:text-link-deep underline transition-colors duration-150">
          openprojects50@gmail.com
        </a>
        {" "}and we will get back to you within 1–2 business days.
      </p>
      <p class="text-body text-sm leading-relaxed">
        Please include your name, a brief subject, and a description of your feedback, suggestion, or bug report.
      </p>
      <a
        href="mailto:openprojects50@gmail.com?subject=Feedback%20for%20Free%20Online%20Tools%20Nest"
        class="btn-primary inline-flex"
        style="background-color: var(--color-primary); color: var(--color-on-primary); text-decoration: none;"
      >
        Send us an email
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
    </div>
  </div>
</Layout>
