---
import Layout from "../layouts/Layout.astro";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("en");
---

<Layout
  title={t("err.500Title")}
  description={t("err.500Desc")}
  noindex={true}
>
  <div class="container-page py-20 md:py-32 text-center">
    <p class="text-6xl font-semibold text-hairline mb-4" style="letter-spacing: -2.4px;">500</p>
    <h1 class="text-2xl md:text-3xl font-semibold text-ink mb-3" style="letter-spacing: -0.96px;">
      {t("err.500Headline")}
    </h1>
    <p class="text-body max-w-md mx-auto mb-8">
      {t("err.500Desc")}
    </p>
    <div class="flex items-center justify-center gap-3 flex-wrap">
      <button
        type="button"
        onclick="window.location.reload()"
        class="btn-primary"
        style="background-color: var(--color-primary); color: var(--color-on-primary);"
      >
        {t("err.tryAgain")}
      </button>
      <a href="/en/" class="btn-secondary" style="border-color: var(--color-hairline); color: var(--color-ink); background-color: var(--color-canvas);">
        {t("err.goHome")}
      </a>
    </div>
  </div>
</Layout>
