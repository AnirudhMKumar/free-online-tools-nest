---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../data/tools";
---

<Layout
  title="About"
  description={`Learn about ${SITE.name} — our mission to provide free, fast, and private online tools for everyone.`}
  canonicalPath="/about/"
>
  <div class="container-narrow py-12 md:py-20">
    <h1 class="text-3xl md:text-4xl font-semibold text-ink mb-6" style="letter-spacing: -1.28px;">
      About {SITE.name}
    </h1>

    <div class="space-y-6 text-body leading-relaxed">
      <p>
        {SITE.name} is a collection of free online tools built for speed, privacy, and simplicity. We serve writers, developers, students, marketers, and anyone who needs quick utility tools without the hassle of downloads, sign-ups, or subscriptions.
      </p>

      <h2 class="text-xl font-semibold text-ink mt-8" style="letter-spacing: -0.6px;">Our mission</h2>
      <p>
        We believe essential tools should be free and accessible. Our mission is to build the fastest, most private, and most useful collection of online tools on the internet. Every tool processes data locally in your browser — nothing is ever uploaded to our servers.
      </p>

      <h2 class="text-xl font-semibold text-ink mt-8" style="letter-spacing: -0.6px;">What we offer</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li><strong>Text tools</strong> — word counters, character counters, case converters, and text generators.</li>
        <li><strong>Developer tools</strong> — JSON formatters, URL encoders, Base64 converters, and more.</li>
        <li><strong>Calculators</strong> — percentage calculators and mathematical utilities.</li>
        <li><strong>Converters</strong> — QR code generators, color converters, and format transformers.</li>
      </ul>

      <h2 class="text-xl font-semibold text-ink mt-8" style="letter-spacing: -0.6px;">Our principles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
        {[
          { title: "Free forever", desc: "No premium tiers, no paywalls, no ads." },
          { title: "Privacy by design", desc: "All processing happens in your browser. We never see your data." },
          { title: "Fast by default", desc: "Lightweight code, no bloat, instant results." },
          { title: "Open and honest", desc: "No dark patterns, no tricks, no hidden costs." },
        ].map((item) => (
          <div class="card p-4">
            <h3 class="text-sm font-semibold text-ink mb-1">{item.title}</h3>
            <p class="text-sm text-body">{item.desc}</p>
          </div>
        ))}
      </div>

      <p class="mt-8">
        Have a suggestion for a new tool? We would love to hear from you.
        <a href="/contact/" class="text-link hover:text-link-deep underline">Get in touch</a>.
      </p>
    </div>
  </div>
</Layout>
