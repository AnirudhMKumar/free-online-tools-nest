---
/**
 * About — root-level English page for SEO.
 * Canonical version; locale versions link here as the canonical.
 */
import Layout from "../layouts/Layout.astro";
import { SITE } from "../data/tools";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("en");
---

<Layout
  title={t("about.metaTitle")}
  description={t("about.metaDesc")}
  canonicalPath="/about/"
>
  <div class="container-narrow py-12 md:py-20">
    <h1 class="text-3xl md:text-4xl font-semibold text-ink mb-6" style="letter-spacing: -1.28px;">
      {t("about.title").replace("{name}", SITE.name)}
    </h1>

    <div class="space-y-6 text-body leading-relaxed">
      <p>
        {t("about.p1").replace("{name}", SITE.name)}
      </p>

      <h2 class="text-xl font-semibold text-ink mt-8" style="letter-spacing: -0.6px;">{t("about.missionTitle")}</h2>
      <p>
        {t("about.missionText")}
      </p>

      <h2 class="text-xl font-semibold text-ink mt-8" style="letter-spacing: -0.6px;">{t("about.offerTitle")}</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>{t("about.offerItem1")}</li>
        <li>{t("about.offerItem2")}</li>
        <li>{t("about.offerItem3")}</li>
        <li>{t("about.offerItem4")}</li>
      </ul>

      <h2 class="text-xl font-semibold text-ink mt-8" style="letter-spacing: -0.6px;">{t("about.principlesTitle")}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
        {[
          { title: t("about.principle1Title"), desc: t("about.principle1Desc") },
          { title: t("about.principle2Title"), desc: t("about.principle2Desc") },
          { title: t("about.principle3Title"), desc: t("about.principle3Desc") },
          { title: t("about.principle4Title"), desc: t("about.principle4Desc") },
        ].map((item) => (
          <div class="card p-4">
            <h3 class="text-sm font-semibold text-ink mb-1">{item.title}</h3>
            <p class="text-sm text-body">{item.desc}</p>
          </div>
        ))}
      </div>

      <p class="mt-8">
        {t("about.ctaText")}
        <a href="/contact/" class="text-link hover:text-link-deep underline">{t("about.ctaLink")}</a>.
      </p>
    </div>
  </div>
</Layout>
