---
/**
 * About — root-level redirect page.
 * Detects browser language and redirects to the locale-prefixed version.
 * Acts as the x-default target for hreflang.
 */
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About — Free Online Tools Nest</title>
  <meta http-equiv="refresh" content="0;url=/en/about/" />
  <meta name="robots" content="noindex, follow" />
  <script is:inline>
    (function() {
      var lang = (navigator.language || navigator.languages?.[0] || '').slice(0, 2);
      var supported = ['es', 'pt', 'fr', 'de', 'hi', 'ja', 'ar'];
      window.location.href = '/' + (supported.includes(lang) ? lang : 'en') + '/about/';
    })();
  </script>
</head>
<body>
  <a href="/en/about/">About — Free Online Tools Nest</a>
</body>
</html>
