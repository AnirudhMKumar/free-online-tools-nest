      intro: "हम text, code, PDF, images, SEO और productivity tasks के लिए मुफ्त online tools बनाते हैं. Focus speed, clarity और privacy पर है.",
      sections: [
        { heading: "Privacy first", body: "जहां tool browser में चल सकता है, आपका data local process होता है और server पर upload नहीं होता." },
        { heading: "Real work के लिए", body: "Collection writers, developers, students और teams के लिए है जिन्हें छोटे काम बिना software install किए करने हैं." },
      ],
      cta: { label: "संपर्क करें", href: "/hi/contact/" },
