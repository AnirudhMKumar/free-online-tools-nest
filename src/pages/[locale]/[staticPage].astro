    },
    "terms-and-conditions": {
      title: "Términos y condiciones — Free Online Tools Nest",
      description: "Resumen de términos para usar las herramientas localizadas de Free Online Tools Nest.",
      heading: "Términos y condiciones",
      intro: "Este resumen localizado explica el uso básico del sitio. La versión inglesa principal contiene los términos completos.",
      sections: [
        { heading: "Uso permitido", body: "Puedes usar las herramientas gratis para fines personales o comerciales, siempre que el uso sea legal." },
        { heading: "Sin garantía profesional", body: "Las herramientas se ofrecen tal cual y no reemplazan asesoría legal, financiera, médica, fiscal o profesional." },
