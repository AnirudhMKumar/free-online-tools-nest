---
import Layout from "../../layouts/Layout.astro";
import { SITE } from "../../data/tools";
import { PUBLISHED_LOCALES } from "../../data/localized";
import { getDefaultAlternates } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";

const staticPages = ["about", "contact", "faq", "privacy-policy", "terms-and-conditions"] as const;
type StaticPage = (typeof staticPages)[number];

type PageCopy = {
  title: string;
  description: string;
  heading: string;
  intro: string;
  sections: { heading: string; body: string }[];
  cta?: { label: string; href: string };
};

const copies: Record<Exclude<Lang, "en">, Record<StaticPage, PageCopy>> = {
  es: {
    about: {
      title: "Acerca de Free Online Tools Nest",
      description: "Conoce Free Online Tools Nest, una colección de herramientas online gratis, rápidas y privadas.",
      heading: "Acerca de Free Online Tools Nest",
      intro: "Creamos herramientas online gratis para tareas de texto, código, PDF, imágenes, SEO y productividad. La prioridad es que sean rápidas, claras y privadas.",
      sections: [
        { heading: "Privacidad primero", body: "Siempre que una herramienta puede ejecutarse en el navegador, tus datos se procesan localmente y no se suben a un servidor." },
