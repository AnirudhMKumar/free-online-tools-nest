    },
    contact: {
      title: "Contacto — Free Online Tools Nest",
      description: "Envía feedback, sugerencias de herramientas o reportes de errores.",
      heading: "Contacto",
      intro: "¿Tienes una sugerencia, encontraste un error o quieres pedir una herramienta nueva? Escríbenos.",
