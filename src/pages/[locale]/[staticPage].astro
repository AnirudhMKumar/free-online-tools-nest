      heading: "गोपनीयता नीति",
      intro: "यह localized privacy summary है. Complete policy English page पर उपलब्ध है.",
      sections: [
        { heading: "Tool data", body: "Text, files, passwords, images और PDFs browser में रहते हैं जब tool local processing support करता है." },
        { heading: "Analytics और external services", body: "हम aggregate usage measurement के लिए Google Analytics, typography के लिए Google Fonts और clicked external links पर third-party services use करते हैं." },
        { heading: "Contact", body: "Privacy questions के लिए openprojects50@gmail.com पर लिखें." },
      ],
      cta: { label: "English full policy", href: "/privacy-policy/" },
    },
    "terms-and-conditions": {
      title: "नियम और शर्तें — Free Online Tools Nest",
      description: "Free Online Tools Nest localized tools use करने के terms का summary.",
      heading: "नियम और शर्तें",
      intro: "यह localized terms summary है. Complete English terms main page पर उपलब्ध हैं.",
      sections: [
        { heading: "Allowed use", body: "Tools personal या commercial work के लिए free use कर सकते हैं, जब तक use legal है." },
        { heading: "Professional advice नहीं", body: "Tools as-is दिए जाते हैं और legal, financial, medical, tax या professional advice नहीं हैं." },
        { heading: "Responsibility", body: "Outputs पर rely करने से पहले उन्हें review करना आपकी responsibility है." },
      ],
      cta: { label: "English full terms", href: "/terms-and-conditions/" },
    },
  },
};

export function getStaticPaths() {
  const paths = ["about", "contact", "faq", "privacy-policy", "terms-and-conditions"] as const;
  return PUBLISHED_LOCALES.flatMap((locale) =>
    paths.map((staticPage) => ({ params: { locale, staticPage } }))
  );
}

const lang = Astro.params.locale as Exclude<Lang, "en">;
const staticPage = Astro.params.staticPage as StaticPage;
const copy = copies[lang][staticPage];
const rootPath = `/${staticPage}/`;
const canonicalPath = `/${lang}${rootPath}`;
const alternatePaths = getDefaultAlternates(rootPath);
const webPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${SITE.url}${canonicalPath}`,
  name: copy.title,
  description: copy.description,
  url: `${SITE.url}${canonicalPath}`,
  isPartOf: { "@type": "WebSite", name: SITE.name, url: SITE.url },
};
---

<Layout
  title={copy.title}
  description={copy.description}
  canonicalPath={canonicalPath}
  alternatePaths={alternatePaths}
  jsonLd={webPageJsonLd}
  lang={lang}
>
  <div class="container-narrow py-12 md:py-20">
    <h1 class="text-3xl md:text-4xl font-semibold text-ink mb-4" style="letter-spacing: 0;">
      {copy.heading}
    </h1>
    <p class="text-body text-lg leading-relaxed mb-10">{copy.intro}</p>

    <article class="space-y-6 text-body leading-relaxed">
      {copy.sections.map((section) => (
        <section>
          <h2 class="text-xl font-semibold text-ink mb-3" style="letter-spacing: 0;">{section.heading}</h2>
          <p>{section.body}</p>
        </section>
      ))}
    </article>

    {copy.cta && (
      <a href={copy.cta.href} class="btn-primary inline-flex mt-10 no-underline">
        {copy.cta.label}
      </a>
    )}
  </div>
</Layout>

