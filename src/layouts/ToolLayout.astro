---
/**
 * ToolLayout — layout for individual tool pages.
 * Extends Layout with breadcrumbs, tool description, related tools sidebar.
 */
interface Props {
  title: string;
  description: string;
  toolSlug: string;
  categorySlug: string;
  categoryName: string;
  longDescription: string;
  keywords?: string[];
}

import Layout from "./Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ToolCard from "../components/ToolCard.astro";
import FAQSection from "../components/FAQSection.astro";
import FavoriteButton from "../components/FavoriteButton";
import ShareBar from "../components/ShareBar.astro";
import { getRelatedTools, getCategoryBySlug, getToolBySlug, SITE } from "../data/tools";

const {
  title,
  description,
  toolSlug,
  categorySlug,
  categoryName,
  longDescription,
  keywords = [],
} = Astro.props;

const relatedTools = getRelatedTools(toolSlug, 4);
const category = getCategoryBySlug(categorySlug);
const tool = getToolBySlug(toolSlug);

const finalMetaTitle = tool?.metaTitle || `${title} Online — Free ${categoryName} Tool`;
const finalMetaDescription = tool?.metaDescription || description;

const breadcrumbs = [
  { label: "Tools", href: "/tools/" },
  { label: categoryName, href: `/categories/${categorySlug}/` },
  { label: title },
];

// WebApplication JSON-LD for the tool
const toolJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: title,
  description: finalMetaDescription,
  url: `${SITE.url}/tools/${toolSlug}/`,
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};

// BreadcrumbList JSON-LD
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: SITE.url,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Tools",
      item: `${SITE.url}/tools/`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: categoryName,
      item: `${SITE.url}/categories/${categorySlug}/`,
    },
    {
      "@type": "ListItem",
      position: 4,
      name: title,
      item: `${SITE.url}/tools/${toolSlug}/`,
    },
  ],
};

const combinedJsonLd = [toolJsonLd, breadcrumbJsonLd];
const ogImage = `/og/${categorySlug}.png`;
---

<Layout
  title={finalMetaTitle}
  description={finalMetaDescription}
  canonicalPath={`/tools/${toolSlug}/`}
  ogImage={ogImage}
  jsonLd={combinedJsonLd}
>
  <div class="container-page py-8 md:py-12">
    <Breadcrumbs items={breadcrumbs} />

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8 lg:gap-12">
      <!-- Main tool area -->
      <div>
        <header class="mb-8">
          <h1 class="text-3xl md:text-4xl font-semibold text-ink" style="letter-spacing: -1.28px;">
            {title}
          </h1>
          <p class="mt-3 text-body text-lg leading-relaxed max-w-2xl">
            {longDescription}
          </p>
        </header>

        <!-- Tool component slot -->
        <div class="card p-4 sm:p-6 md:p-8">
          <slot />
        </div>

        <!-- Favorite + Share -->
        <div class="mt-4 flex items-center gap-3 flex-wrap">
          <FavoriteButton client:load toolSlug={toolSlug} />
          <ShareBar title={title} url={`${SITE.url}/tools/${toolSlug}/`} />
        </div>

        <!-- Keywords for SEO -->
        {keywords.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {keywords.map((kw) => (
              <span class="text-xs text-mute bg-canvas-soft-2 px-2.5 py-1 rounded-full">
                {kw}
              </span>
            ))}
          </div>
        )}

        <!-- How to Use section -->
        {tool?.usageSteps && tool.usageSteps.length > 0 && (
          <section class="mt-12 border-t border-hairline pt-10">
            <h2 class="text-xl font-semibold text-ink mb-6" style="letter-spacing: -0.6px;">
              How to use the {title}
            </h2>
            <div class="space-y-6">
              {tool.usageSteps.map((step, i) => (
                <div class="flex gap-4">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-ink text-canvas flex items-center justify-center text-sm font-semibold">
                    {i + 1}
                  </span>
                  <div>
                    <h3 class="text-base font-medium text-ink mb-1">{step.title}</h3>
                    <p class="text-sm text-body leading-relaxed">{step.content}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="mt-12 lg:mt-0 lg:block">
        <div class="sticky top-20">
          <h2 class="text-xs font-mono font-normal uppercase tracking-wider text-mute mb-4">
            Related tools
          </h2>
          <div class="space-y-3">
            {relatedTools.map((tool) => (
              <ToolCard
                slug={tool.slug}
                name={tool.name}
                description={tool.description}
                icon={tool.icon}
                categorySlug={tool.categorySlug}
              />
            ))}
          </div>

          {category && (
            <a
              href={`/categories/${categorySlug}/`}
              class="inline-flex items-center gap-1 mt-6 text-sm text-link hover:text-link-deep transition-colors duration-150"
            >
              View all {categoryName}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </a>
          )}
        </div>
      </aside>
    </div>

    <!-- Tool-specific FAQ -->
    {tool?.faq && tool.faq.length > 0 && (
      <FAQSection items={tool.faq} title={`${title} — Frequently Asked Questions`} />
    )}
  </div>
</Layout>

