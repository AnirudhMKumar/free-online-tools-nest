---
/**
 * ToolLayout — layout for individual tool pages.
 * Extends Layout with breadcrumbs, app panel, tool description, related tools sidebar.
 */
interface Props {
  title: string;
  description: string;
  toolSlug: string;
  categorySlug: string;
  categoryName: string;
  longDescription: string;
  keywords?: string[];
  metaTitle?: string;
  metaDescription?: string;
  usageSteps?: UsageStep[];
  faq?: FAQPair[];
  additionalContent?: ContentSection[];
  locale?: Lang;
  canonicalPath?: string;
  alternatePaths?: Record<string, string>;
}

import Layout from "./Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ToolCard from "../components/ToolCard.astro";
import FAQSection from "../components/FAQSection.astro";
import FavoriteButton from "../components/FavoriteButton";
import ShareBar from "../components/ShareBar.astro";
import { getRelatedTools, getCategoryBySlug, getToolBySlug, SITE } from "../data/tools";
import type { ContentSection, FAQPair, UsageStep } from "../data/tools";
import { getLocalizedRelatedTools, hasLocalizedTool, PUBLISHED_LOCALES } from "../data/localized";
import { defaultLang } from "../i18n/ui";
import type { Lang } from "../i18n/ui";

const {
  title,
  description,
  toolSlug,
  categorySlug,
  categoryName,
  longDescription,
  keywords = [],
  metaTitle,
  metaDescription,
  usageSteps,
  faq,
  additionalContent,
  locale = defaultLang,
  canonicalPath = `/tools/${toolSlug}/`,
  alternatePaths,
} = Astro.props;

const localePrefix = locale === defaultLang ? "" : `/${locale}`;
const toolsPath = `${localePrefix}/tools/`;
const categoryPath = `${localePrefix}/categories/${categorySlug}/`;
const relatedTools = locale === defaultLang ? getRelatedTools(toolSlug, 4) : getLocalizedRelatedTools(locale, toolSlug, 4);
const category = getCategoryBySlug(categorySlug);
const tool = getToolBySlug(toolSlug);

const finalMetaTitle = metaTitle || tool?.metaTitle || `${title} Online — Free ${categoryName} Tool`;
const finalMetaDescription = metaDescription || tool?.metaDescription || description;
const finalUsageSteps = usageSteps || tool?.usageSteps;
const finalFaq = faq || tool?.faq;
const finalAdditionalContent = additionalContent || tool?.additionalContent;
const finalAlternatePaths = alternatePaths || (locale === defaultLang && PUBLISHED_LOCALES.some((lang) => hasLocalizedTool(lang, toolSlug))
  ? {
      en: canonicalPath,
      ...Object.fromEntries(PUBLISHED_LOCALES.filter((lang) => hasLocalizedTool(lang, toolSlug)).map((lang) => [lang, `/${lang}${canonicalPath}`])),
      "x-default": canonicalPath,
    }
  : alternatePaths);

const breadcrumbs = [
  { label: "Tools", href: toolsPath },
  { label: categoryName, href: categoryPath },
  { label: title },
];

const toolJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: title,
  description: finalMetaDescription,
  url: `${SITE.url}${canonicalPath}`,
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  browserRequirements: "Requires JavaScript",
  softwareVersion: "1.0",
  author: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
  },
  image: `${SITE.url}/og/${categorySlug}.png`,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: `${SITE.url}${canonicalPath}`,
    priceValidUntil: "2030-12-31",
  },
  about: {
    "@type": "Thing",
    name: title,
    description: finalMetaDescription,
  },
};

const combinedJsonLd = [toolJsonLd];
const ogImage = `/og/${categorySlug}.png`;
---

<Layout
  title={finalMetaTitle}
  description={finalMetaDescription}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  jsonLd={combinedJsonLd}
  lang={locale}
  alternatePaths={finalAlternatePaths}
>
  <div class="container-page py-8 md:py-10">
    <Breadcrumbs items={breadcrumbs} />

    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_320px] gap-8 lg:gap-10">
      <div class="min-w-0">
        <header class="app-panel overflow-hidden p-5 sm:p-7 md:p-8 mb-6">
          <div class="flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
            <div class="max-w-3xl">
              <div class="mb-4 flex flex-wrap gap-2">
                <a href={categoryPath} class="metadata-badge no-underline">
                  {category?.icon && <span aria-hidden="true">{category.icon}</span>} {categoryName}
                </a>
                <span class="metadata-badge">No uploads</span>
                <span class="metadata-badge">Runs in your browser</span>
              </div>
              <h1 class="text-3xl md:text-4xl font-semibold text-ink text-balance" style="letter-spacing: 0; line-height: 1.08;">
                {title}
              </h1>
              <p class="mt-3 text-body text-base md:text-lg leading-relaxed max-w-3xl text-pretty">
                {longDescription}
              </p>
            </div>

            <div class="flex items-center gap-3 flex-wrap xl:justify-end">
              <FavoriteButton client:load toolSlug={toolSlug} />
              <ShareBar title={title} url={`${SITE.url}${canonicalPath}`} />
            </div>
          </div>
        </header>

        <section class="app-panel overflow-hidden" aria-label={`${title} tool`}>
          <div class="flex flex-wrap items-center justify-between gap-3 border-b border-hairline px-4 py-3 sm:px-6">
            <div>
              <p class="text-sm font-medium text-ink">Workspace</p>
              <p class="text-xs text-mute">Use the tool below. Your inputs stay local when the tool supports browser-only processing.</p>
            </div>
            <a href={toolsPath} class="pill-control">All tools</a>
          </div>
          <div class="p-4 sm:p-6 md:p-8">
            <slot />
          </div>
        </section>

        {keywords.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2" aria-label="Tool keywords">
            {keywords.map((kw) => (
              <span class="metadata-badge">{kw}</span>
            ))}
          </div>
        )}

        {finalUsageSteps && finalUsageSteps.length > 0 && (
          <section class="mt-10 border-t border-hairline pt-8">
            <div class="section-heading">
              <div>
                <p class="section-eyebrow">Workflow</p>
                <h2 class="section-title">How to use the {title}</h2>
              </div>
            </div>
            <div class="grid gap-4 md:grid-cols-3">
              {finalUsageSteps.map((step, i) => (
                <article class="card p-5">
                  <span class="mb-4 flex h-8 w-8 items-center justify-center rounded-full bg-primary text-sm font-semibold text-on-primary">
                    {i + 1}
                  </span>
                  <h3 class="text-base font-semibold text-ink mb-2">{step.title}</h3>
                  <p class="text-sm text-body leading-relaxed">{step.content}</p>
                </article>
              ))}
            </div>
          </section>
        )}

        {finalAdditionalContent && finalAdditionalContent.length > 0 && (
          <section class="mt-10 border-t border-hairline pt-8">
            <div class="grid gap-5 md:grid-cols-3">
              {finalAdditionalContent.map((block) => (
                <article class="rounded-lg border border-hairline bg-canvas p-5">
                  <h2 class="text-lg font-semibold text-ink mb-3" style="letter-spacing: 0;">
                    {block.heading}
                  </h2>
                  <p class="text-sm text-body leading-relaxed">{block.content}</p>
                </article>
              ))}
            </div>
          </section>
        )}
      </div>

      <aside class="mt-4 lg:mt-0 lg:block">
        <div class="sticky top-24 space-y-5">
          <section class="app-panel p-4">
            <div class="mb-4 flex items-center justify-between gap-3">
              <h2 class="text-xs font-mono font-normal text-mute">
                Related tools
              </h2>
              {category && (
                <a href={categoryPath} class="text-xs font-medium text-link hover:text-link-deep transition-colors duration-150">
                  View all
                </a>
              )}
            </div>
            <div class="space-y-3">
              {relatedTools.map((tool) => (
                <ToolCard
                  slug={tool.slug}
                  href={`${localePrefix}/tools/${tool.slug}/`}
                  name={tool.name}
                  description={tool.description}
                  icon={tool.icon}
                  categorySlug={tool.categorySlug}
                  variant="compact"
                />
              ))}
            </div>
          </section>

          <section class="rounded-lg border border-hairline bg-canvas-soft p-4">
            <p class="text-sm font-medium text-ink">Private by design</p>
            <p class="mt-1 text-xs leading-relaxed text-body">Free Online Tools Nest prioritizes browser-based workflows, no signups, and clean utility pages without ad clutter.</p>
          </section>
        </div>
      </aside>
    </div>

    {finalFaq && finalFaq.length > 0 && (
      <FAQSection items={finalFaq} title={`${title} — Frequently Asked Questions`} />
    )}
  </div>
</Layout>
