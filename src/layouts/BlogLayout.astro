---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}
import Layout from "./Layout.astro";
const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;
---

<Layout title={title} description={description}>
  <article class="container-narrow py-12">
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-semibold text-ink" style="letter-spacing: -1.28px;">
        {title}
      </h1>
      <div class="mt-4 flex items-center gap-3 text-sm text-mute">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString("en-US", {
            year: "numeric", month: "long", day: "numeric",
          })}
        </time>
        {updatedDate && (
          <span>(Updated {updatedDate.toLocaleDateString("en-US", {
            year: "numeric", month: "long", day: "numeric",
          })})</span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="text-xs text-mute bg-canvas-soft-2 px-2.5 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>
    <div class="prose-like max-w-none">
      <slot />
    </div>
  </article>
</Layout>
