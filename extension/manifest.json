{
  "manifest_version": 3,
  "name": "Free Online Tools Nest",
  "version": "1.0.0",
  "description": "Quick access to free online tools — text, code, math, PDF, and converters. All client-side, no sign-up required.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [],
  "host_permissions": [],
  "chrome_url_overrides": {}
}
